# APGI Framework Environment Configuration

VITE_API_BASE_URL=https://api.apgi-framework.com
VITE_API_TIMEOUT=10000

# Security Configuration
JWT_SECRET=your-super-secure-jwt-secret-key-change-this-in-production
ADMIN_API_KEY=your-secure-admin-api-key-change-this-in-production

# Email Service Configuration
VITE_EMAIL_PROVIDER=mailchimp
# Options: local, mailchimp, convertkit

# Mailchimp Configuration (Production)
VITE_MAILCHIMP_API_KEY=your_production_mailchimp_api_key
VITE_MAILCHIMP_SERVER_PREFIX=us1
VITE_MAILCHIMP_SNAPSHOT_LIST_ID=your_snapshot_list_id
VITE_MAILCHIMP_NEWSLETTER_LIST_ID=your_newsletter_list_id
VITE_MAILCHIMP_CONSULTATIONS_LIST_ID=your_consultations_list_id

# ConvertKit Configuration (Alternative)
VITE_CONVERTKIT_API_KEY=your_production_convertkit_api_key
VITE_CONVERTKIT_SNAPSHOT_FORM_ID=your_snapshot_form_id
VITE_CONVERTKIT_PROFESSIONAL_FORM_ID=your_professional_form_id

# Stripe Configuration (Production)
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_your_production_stripe_publishable_key
VITE_STRIPE_PROFESSIONAL_PRICE_ID=price_your_professional_price_id
VITE_STRIPE_ENTERPRISE_PRICE_ID=price_your_enterprise_price_id

# Analytics Configuration (Production)
VITE_ANALYTICS_PROVIDER=plausible
# Options: local, google, plausible

# Google Analytics (if using Google Analytics)
VITE_GA_TRACKING_ID=GA-XXXXXXXXX

# Plausible Analytics (Recommended for privacy)
VITE_PLAUSIBLE_DOMAIN=apgi-framework.com

# Feature Flags (Production)
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_EMAIL_CAPTURE=true
VITE_ENABLE_PAYMENTS=true
VITE_DEBUG_MODE=false

# Production Database (when implemented)
DATABASE_URL=postgresql://username:password@localhost:5432/apgi_production
REDIS_URL=redis://localhost:6379

# Production Server Configuration
PORT=3001
NODE_ENV=production

# CORS Configuration (Production)
ALLOWED_ORIGINS=https://apgi-framework.com,https://www.apgi-framework.com

# Rate Limiting (Production)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
API_RATE_LIMIT_MAX_REQUESTS=20

# Security Headers
HELMET_CSP_DIRECTIVE_DEFAULT_SELF=true
HELMET_CSP_DIRECTIVE_STYLE_SELF_UNSAFE_INLINE=true
HELMET_CSP_DIRECTIVE_FONT_SELF=true
HELMET_CSP_DIRECTIVE_SCRIPT_SELF=true
HELMET_CSP_DIRECTIVE_IMG_SELF_DATA=true

# SSL Configuration
SSL_CERT_PATH=/etc/ssl/certs/apgi-framework.crt
SSL_KEY_PATH=/etc/ssl/private/apgi-framework.key

# Monitoring and Logging
LOG_LEVEL=warn
SENTRY_DSN=your_sentry_dsn_for_error_tracking

# Backup Configuration
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_S3_BUCKET=apgi-backups
